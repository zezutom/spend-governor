# corpus snapshot is baked into the image).
.git
.venv
__pycache__
*.pyc
.pytest_cache
.ruff_cache
.mypy_cache

# rebuilt inside the image
web/node_modules
web/dist

# local-only
.env
*.log
data/*.log
data/*.bak-*
gitignore/
.claude/
.DS_Store
